# Discord Bot Token（Discord Developer Portal から取得）
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord Application ID / Public Key（Discord Developer Portal の General Information）
DISCORD_APPLICATION_ID=your_discord_application_id_here
DISCORD_PUBLIC_KEY=your_discord_public_key_here

# 任意: Slash Commandを即時反映したい開発用サーバーID（未設定ならグローバルコマンド）
DISCORD_GUILD_ID=

# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model（必要に応じて変更）
ANTHROPIC_MODEL=claude-sonnet-4-6

# 雑記を書くチャンネルのID（チャンネル名を右クリック→「IDをコピー」）
DISCORD_MEMO_CHANNEL_ID=000000000000000000

# 日報・月次サマリーを投稿するチャンネルのID
DISCORD_REPORT_CHANNEL_ID=000000000000000001

# 任意: 手動コマンドを許可するDiscordユーザーID（カンマ区切り、未設定なら日報チャンネル内の全ユーザーを許可）
DISCORD_ALLOWED_USER_IDS=
